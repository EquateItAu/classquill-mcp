{
  "name": "equateit-mcp",
  "version": "1.0.2",
  "mcpName": "io.github.EquateItAu/classquill-mcp",
  "type": "module",
  "description": "EquateIt MCP server — read-only access to your org's tutoring data (sessions, invoices, students, earnings…) via the EquateIt public API.",
  "license": "MIT",
  "bin": {
    "equateit-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "gen:tools": "node scripts/generate-tools.mjs",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "keywords": [
    "equateit",
    "mcp",
    "model-context-protocol",
    "tutoring"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.0"
  }
}
